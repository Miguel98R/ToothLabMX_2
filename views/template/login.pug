.container
    section.vh-100
        .container-fluid.h-custom
            .card
                .card-header
                    h3
                        i.fa-solid.fa-door-open
                        |   Bienvenido de nuevo

                .card-body
                    .row.d-flex.justify-content-center.align-items-center.h-100
                        .col-md-9.col-lg-6.col-xl-5.text-center
                            img.img-fluid.mx-2.my-2( style='width:65%;'  src='/public/img/logo.jpg' alt='Sample image')
                        .col-md-8.col-lg-6.col-xl-4

                            .card
                                .card-header.text-center

                                    h4
                                        |   Inicio de sesión
                                .card-body.text-secondary
                                    .form-outline.my-2
                                        label.form-label(for='user')
                                            i.fa-solid.fa-user-tie
                                            b|  Usuario:
                                        input#user.form-control(type='text')


                                    .form-outline.my-2
                                        label.form-label(for='password')
                                            i.fa-solid.fa-key
                                            b|  Contraseña :
                                        input#password.form-control(type='password')


                                .card-footer.text-center

                                    #reset_password(style="display:none;")
                                        button.btn.btn-link.reset_constra|¿ Olvidaste tu contraseña ?
                                    #reset_user(style="display:none;")
                                        button.btn.btn-link.reset_user|Crear nuevo usuario
                                    br
                                    button.btn.btn-dark(style='padding-left: 2.5rem; padding-right: 2.5rem;')#entrar
                                        i.fas.fa-sign-in-alt
                                        |  Entrar


                .card-footer.bg-transparent.border-0.py-4
                    .d-flex.flex-column.align-items-center.justify-content-center
                        .text-secondary.mb-2(style="font-size: 0.9rem; letter-spacing: 0.5px;")
                            i.fa-regular.fa-copyright.me-1
                            | 2020-2026 
                            strong.text-dark Mike Rosas Dev
                            span.mx-2 |
                            | ToothLabMX v2.3.6
                        .text-secondary(style="font-size: 0.85rem;")
                            span Desarrollado por: 
                            a.ms-1(href='https://mikerosasdev.com/' target='_blank' style="text-decoration: none; font-weight: 600; color: #0284c7; transition: color 0.3s;")
                                i.fa-solid.fa-globe.me-1
                                | mikerosasdev.com





        br

